{
  "name": "vanguard.angular",
  "version": "0.1.0",
  "description": "This is the Vanguard Client Application",
  "author": "Luc Joosten",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host=127.0.0.1",
    "build:dev": "ng build --configuration=development",
    "build:staging": "ng build --configuration=staging",
    "build:production": "ng build --configuration=production",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.1.0",
    "@angular/common": "^19.2.2",
    "@angular/compiler": "^19.1.0",
    "@angular/core": "^19.2.2",
    "@angular/forms": "^19.2.2",
    "@angular/material": "^19.2.3",
    "@angular/platform-browser": "^19.1.0",
    "@angular/platform-browser-dynamic": "^19.1.0",
    "@angular/router": "^19.1.0",
    "@ngrx/effects": "^19.0.1",
    "@ngrx/entity": "^19.0.1",
    "@ngrx/store": "^19.0.1",
    "@ngx-formly/core": "^6.3.12",
    "@ngx-formly/material": "^6.3.12",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.17.21",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.1.6",
    "@angular/cli": "^19.2.3",
    "@angular/compiler-cli": "^19.1.0",
    "@testing-library/angular": "^17.3.6",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "19.2.1",
    "cypress": "^14.2.0",
    "eslint": "^9.22.0",
    "jasmine-core": "^5.6.0",
    "jest-editor-support": "*",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}